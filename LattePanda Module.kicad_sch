		(uuid "3b763030-399a-4078-9891-420a27a386c7")
	)
	(text "All I2C have integrated pull-up resistors.\nno need to add pull-up resistors"
		(exclude_from_sim no)
		(at 377.444 239.014 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
